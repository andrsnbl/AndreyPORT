# ─────────────────────────────────────────────────────────
# Supabase Configuration
# Get credentials from: https://supabase.com/dashboard
# ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────────────────
# PHASE 3: Supabase Service Role Key (Netlify only)
# Get from: Supabase Dashboard → Project Settings → API → Service Role Secret
# IMPORTANT: Use only in Netlify environment variables, NOT in client code
# ─────────────────────────────────────────────────────────
SUPABASE_SERVICE_ROLE_KEY=sk_your_service_role_key_here

# ─────────────────────────────────────────────────────────
# EmailJS Configuration
# Get credentials from: https://www.emailjs.com/
# DO NOT commit .env file — only .env.example
# ─────────────────────────────────────────────────────────
EMAILJS_SERVICE_ID=your_emailjs_service_id_here
EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# ─────────────────────────────────────────────────────────
# PHASE 3: Sanity.io Configuration (Headless CMS)
# Get credentials from: https://www.sanity.io/
# Create project at: https://manage.sanity.io/
# ─────────────────────────────────────────────────────────
VITE_SANITY_PROJECT_ID=your_sanity_project_id_here
VITE_SANITY_DATASET=production
VITE_SANITY_TOKEN=sk_your_sanity_token_here

# ─────────────────────────────────────────────────────────
# Google Analytics Configuration
# Get Measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
# ─────────────────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=your_ga_measurement_id_here

