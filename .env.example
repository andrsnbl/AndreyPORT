# ─────────────────────────────────────────────────────────
# Supabase Configuration
# Get credentials from: https://supabase.com/dashboard
# ─────────────────────────────────────────────────────────
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─────────────────────────────────────────────────────────
# EmailJS Configuration
# Get credentials from: https://www.emailjs.com/
# DO NOT commit .env file — only .env.example
# ─────────────────────────────────────────────────────────
VITE_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here
VITE_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
VITE_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here

# ─────────────────────────────────────────────────────────
# Google Analytics Configuration
# Get Measurement ID from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
# ─────────────────────────────────────────────────────────
VITE_GA_MEASUREMENT_ID=your_ga_measurement_id_here

